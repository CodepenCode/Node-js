import { useEffect, useState } from 'react';
import { useGamesQuery, useCreateGameMutation, useJoinGameMutation } from '../hooks/useGameQuery';
import { useAuth, useSocket } from '../context';
import GameBoard from '../components/GameBoard';
import GameStatus from '../components/GameStatus';
import PlayerInfo from '../components/PlayerInfo';
import { RefreshCw, UserPlus } from 'lucide-react';

const GamePage = () => {
  const { user } = useAuth();
  const { socket, socketConnected } = useSocket();
  const { data: games = [], isLoading } = useGamesQuery();
  const createMutation = useCreateGameMutation();
  const joinMutation = useJoinGameMutation();
  
  const [currentGame, setCurrentGame] = useState(null);
  const [gameState, setGameState] = useState({ board: Array(9).fill(null), currentTurn: 'X', status: 'waiting' });

  useEffect(() => {
    if (!socketConnected || !user) return;

    const handleMoveMade = ({ board, currentTurn, winner, status }) => {
      setGameState({ board, currentTurn, winner, status });
    };

    const handlePlayerJoined = () => {
      // Refresh current game
      if (currentGame) setCurrentGame({ ...currentGame, status: 'playing' });
    };

    const handleGameReset = ({ board, currentTurn }) => {
      setGameState({ board, currentTurn, status: 'playing', winner: null });
    };

    socket.on('moveMade', handleMoveMade);
    socket.on('playerJoined', handlePlayerJoined);
    socket.on('gameReset', handleGameReset);

    return () => {
      socket.off('moveMade', handleMoveMade);
      socket.off('playerJoined', handlePlayerJoined);
      socket.off('gameReset', handleGameReset);
    };
  }, [socket, socketConnected, user, currentGame]);

  const handleCreateGame = () => {
    createMutation.mutate(undefined, {
      onSuccess: (game) => {
        setCurrentGame(game);
        socket.emit('joinGame', { gameId: game.id, userId: user.id });
        setGameState({ board: game.board, currentTurn: game.currentTurn, status: game.status });
      },
    });
  };

  const handleJoinGame = (gameId) => {
    joinMutation.mutate({ gameId }, {
      onSuccess: (game) => {
        setCurrentGame(game);
        socket.emit('joinGame', { gameId: game.id, userId: user.id });
        setGameState({ board: game.board, currentTurn: game.currentTurn, status: game.status });
      },
    });
  };

  const handleReset = () => {
    if (currentGame) {
      socket.emit('resetGame', { gameId: currentGame.id });
    }
  };

  const waitingGames = games.filter(g => g.status === 'waiting' && g.player1Id !== user.id);

  if (isLoading) {
    return <div className="min-h-screen flex items-center justify-center"><div>Loading...</div></div>;
  }

  return (
    <div className="min-h-screen p-8 max-w-6xl mx-auto">
      <div className="flex justify-between items-center mb-12">
        <h1 className="text-5xl font-black bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 bg-clip-text text-transparent">
          Tic Tac Toe
        </h1>
        <div className="flex items-center gap-4 text-sm">
          <span className={`px-3 py-1 rounded-full font-bold ${
            socketConnected ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
          }`}>
            {socketConnected ? 'Online' : 'Offline'}
          </span>
          <span>{user.username} ({user.symbol || '?'})</span>
        </div>
      </div>

      {currentGame ? (
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-4xl mx-auto">
          {/* Game Board */}
          <div className="space-y-8">
            <GameBoard
              board={gameState.board}
              gameId={currentGame.id}
              currentTurn={gameState.currentTurn}
              status={gameState.status}
              mySymbol={user.symbol}
              isMyTurn={gameState.currentTurn === user.symbol && gameState.status === 'playing'}
            />
            <GameStatus
              status={gameState.status}
              winner={gameState.winner}
              currentTurn={gameState.currentTurn}
              mySymbol={user.symbol}
            />
          </div>

          {/* Player Info & Controls */}
          <div className="space-y-8">
            <PlayerInfo
              player1={currentGame.player1}
              player2={currentGame.player2}
              myId={user.id}
              currentTurn={gameState.currentTurn}
            />
            <div className="space-y-4">
              <button
                onClick={handleReset}
                disabled={gameState.status !== 'finished'}
                className="w-full bg-gradient-to-r from-green-500 to-blue-500 text-white py-4 px-8 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all disabled:opacity-50"
              >
                <RefreshCw className="w-6 h-6 inline mr-2" />
                New Game
              </button>
            </div>
          </div>
        </div>
      ) : (
        <div className="max-w-2xl mx-auto">
          <h2 className="text-3xl font-bold text-center mb-12 text-gray-800">
            Choose a Game
          </h2>
          
          {/* Create New Game */}
          <div className="bg-white/70 backdrop-blur-xl rounded-3xl p-12 shadow-2xl mb-8 text-center">
            <button
              onClick={handleCreateGame}
              disabled={createMutation.isPending}
              className="bg-gradient-to-r from-blue-500 to-purple-500 text-white py-8 px-12 rounded-2xl font-bold text-2xl shadow-2xl hover:shadow-3xl transform hover:-translate-y-2 transition-all w-full max-w-md mx-auto disabled:opacity-50"
            >
              <UserPlus className="w-12 h-12 inline mr-4 mb-4 block" />
              Create New Game
            </button>
          </div>

          {/* Join Existing Games */}
          {waitingGames.length > 0 ? (
            <div className="bg-white/70 backdrop-blur-xl rounded-3xl p-8 shadow-2xl">
              <h3 className="text-2xl font-bold mb-6 text-center">Join Open Games</h3>
              <div className="grid md:grid-cols-2 gap-4">
                {waitingGames.map((game) => (
                  <div key={game.id} className="p-6 border-2 border-dashed border-blue-300 rounded-xl hover:border-blue-400 transition-all bg-blue-50">
                    <p className="font-bold text-lg mb-2">{game.player1.username} (X)</p>
                    <p className="text-sm text-gray-600 mb-4">Waiting for O player...</p>
                    <button
                      onClick={() => handleJoinGame(game.id)}
                      disabled={joinMutation.isPending}
                      className="w-full bg-blue-600 text-white py-3 px-6 rounded-xl font-bold hover:bg-blue-700 transition-all disabled:opacity-50"
                    >
                      Join Game
                    </button>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <p className="text-center text-gray-500 text-lg py-12">
              No open games. Create one to get started!
            </p>
          )}
        </div>
      )}
    </div>
  );
};

export default GamePage;
```

