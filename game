**routes/auth.js**
```js
const express = require('express');
const bcrypt = require('bcryptjs');
const jwt = require('jsonwebtoken');
const { User } = require('../models');
const auth = require('../middleware/auth');

const router = express.Router();

router.post('/register', async (req, res) => {
  try {
    const { username, password } = req.body;
    
    const existingUser = await User.findOne({ where: { username } });
    if (existingUser) {
      return res.status(400).json({ error: 'Username taken' });
    }

    const passwordHash = await bcrypt.hash(password, 10);
    const user = await User.create({ username, passwordHash });
    
    const token = jwt.sign({ id: user.id, username: user.username }, process.env.JWT_SECRET, { expiresIn: '7d' });
    
    res.json({ token, user: { id: user.id, username: user.username } });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

router.post('/login', async (req, res) => {
  try {
    const { username, password } = req.body;
    
    const user = await User.findOne({ where: { username } });
    if (!user || !(await bcrypt.compare(password, user.passwordHash))) {
      return res.status(401).json({ error: 'Invalid credentials' });
    }
    
    const token = jwt.sign({ id: user.id, username: user.username }, process.env.JWT_SECRET, { expiresIn: '7d' });
    
    res.json({ token, user: { id: user.id, username: user.username, wins: user.wins } });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

router.get('/me', auth, async (req, res) => {
  const user = await User.findByPk(req.user.id, {
    attributes: ['id', 'username', 'wins', 'symbol'],
  });
  res.json(user);
});

module.exports = router;
```

**routes/games.js**
```js
const express = require('express');
const { Op } = require('sequelize');
const { Game, User } = require('../models');
const auth = require('../middleware/auth');

const router = express.Router();

router.get('/', auth, async (req, res) => {
  const games = await Game.findAll({
    where: {
      [Op.or]: [
        { player1Id: req.user.id },
        { player2Id: req.user.id },
      ],
    },
    include: [
      { model: User, as: 'player1' },
      { model: User, as: 'player2' },
    ],
    order: [['updatedAt', 'DESC']],
  });
  res.json(games);
});

router.post('/open', auth, async (req, res) => {
  const game = await Game.create({
    player1Id: req.user.id,
  });
  res.json(game);
});

router.post('/join/:gameId', auth, async (req, res) => {
  const game = await Game.findByPk(req.params.gameId);
  if (!game || game.status !== 'waiting') {
    return res.status(400).json({ error: 'Game not available' });
  }

  game.player2Id = req.user.id;
  game.status = 'playing';
  await game.save();

  // Assign symbols
  game.player1.symbol = 'X';
  game.player2.symbol = 'O';
  await Promise.all([game.player1.save(), game.player2.save()]);

  res.json(game);
});

module.exports = router;
```

**sockets/gameHandler.js**
```js
const { Game, User } = require('../models');
const { calculateWinner } = require('../utils/gameLogic'); // You'll implement this

module.exports = (io) => {
  io.on('connection', (socket) => {
    console.log('User connected:', socket.id);

    socket.on('joinGame', async ({ gameId, userId }) => {
      socket.join(gameId);
      socket.to(gameId).emit('playerJoined', { userId });
    });

    socket.on('makeMove', async ({ gameId, index }) => {
      const game = await Game.findByPk(gameId, {
        include: [{ model: User, as: 'player1' }, { model: User, as: 'player2' }],
      });

      if (!game || game.status !== 'playing') return;

      const board = [...game.board];
      if (board[index] || board[index] !== null) return; // Invalid move

      // Determine player symbol from currentTurn
      board[index] = game.currentTurn;

      const winner = calculateWinner(board);
      let gameOver = false;

      if (winner) {
        game.winner = winner;
        game.status = 'finished';
        // Increment winner's wins
        const winningPlayer = game.currentTurn === 'X' ? game.player1 : game.player2;
        winningPlayer.wins += 1;
        await winningPlayer.save();
        gameOver = true;
      } else if (!board.includes(null)) {
        game.status = 'finished'; // Draw
        gameOver = true;
      } else {
        game.currentTurn = game.currentTurn === 'X' ? 'O' : 'X';
      }

      game.board = board;
      await game.save();

      io.to(gameId).emit('moveMade', {
        board,
        currentTurn: game.currentTurn,
        winner,
        status: game.status,
      });
    });

    socket.on('resetGame', async ({ gameId }) => {
      const game = await Game.findByPk(gameId);
      game.board = Array(9).fill(null);
      game.status = 'playing';
      game.currentTurn = 'X';
      game.winner = null;
      await game.save();

      io.to(gameId).emit('gameReset', { board: game.board, currentTurn: 'X' });
    });

    socket.on('disconnect', () => {
      console.log('User disconnected:', socket.id);
    });
  });
};
```

**utils/gameLogic.js** (create this helper)
```js
const lines = [
  [0,1,2], [3,4,5], [6,7,8],
  [0,3,6], [1,4,7], [2,5,8],
  [0,4,8], [2,4,6],
];

function calculateWinner(board) {
  for (let i = 0; i < lines.length; i++) {
    const [a,b,c] = lines[i];
    if (board[a] && board[a] === board[b] && board[a] === board[c]) {
      return board[a];
    }
  }
  return null;
}

module.exports = { calculateWinner };
