import { useState, useEffect, useRef } from 'react';
import { Formik, Form, ErrorMessage } from 'formik';
import * as Yup from 'yup';
import { Sheet, SheetContent, SheetFooter, SheetHeader, SheetTitle } from '../ui/sheet';
import { FloatLabelInput } from '../Common/FloatLabelInput';
import { FloatLabelSelect } from '../Common/FloatLabelSelect';
import { useTranslation } from 'react-i18next';
import { Button } from '../ui/button';
import { useMutation, useQuery } from '@tanstack/react-query';
import { getMasterData } from '../../api/services/masterDataServices';
import { createProduct } from '../../api/services/productServices';
import { Message } from '../ui/message';
import { CurrencyInput } from '../Common/CurrencyInput';
import { FloatLabelTextarea } from '../Common/FloatLabelTextarea';
import { Checkbox } from '../ui/checkbox';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '../ui/dialog';
import { CircleCheck, RefreshCcw } from 'lucide-react';

export default function ProductFormSheet({ isOpen, onClose, product, updateRecord }) {

  const { t, i18n } = useTranslation();
  const isEdit = !!product;

  const [vatList, setVatList] = useState([]);
  const [showVATExemptionModal, setShowVATExemptionModal] = useState(false);
  const [error, setError] = useState("");

  // ✅ Unsaved changes states
  const [showUnsavedWarning, setShowUnsavedWarning] = useState(false);
  const dirtyRef = useRef(false);

  const handleSheetOpenChange = (open) => {
    if (!open) {
      if (dirtyRef.current) {
        setShowUnsavedWarning(true);
      } else {
        onClose();
      }
    }
  };

  const confirmClose = () => {
    setShowUnsavedWarning(false);
    onClose();
  };

  const cancelClose = () => {
    setShowUnsavedWarning(false);
  };

  const { data: masterData } = useQuery({
    queryKey: ['masterData'],
    queryFn: getMasterData,
    enabled: isOpen,
  });

  useEffect(() => {
    if (masterData) {
      setVatList(masterData.data.vatType.map((obj) => ({
        ...obj,
        VATTypeName: `${t(obj.VATTypeName)} (${parseFloat(obj.VATTypeValue)}%)`,
      })));
    }
  }, [masterData, i18n.language]);

  const createProductMutation = useMutation({
    mutationFn: createProduct,
    onSuccess: (res) => {
      if (res && res.status == 1) {
        onClose();
        updateRecord();
      }
    },
    onError: (error) => {
      if (error?.response?.data?.message) {
        setError(error.response.data.message);
        setTimeout(() => setError(""), 3000);
      }
    }
  });

  const vatExemptionCodes = ['E1','E2','E3','E4','E5','E6'];

  return (
    <Sheet open={isOpen} onOpenChange={handleSheetOpenChange}>
      <SheetContent side="right" className="w-full sm:max-w-md overflow-y-auto p-0">
        <SheetHeader>
          <SheetTitle className="text-2xl font-semibold">
            {isEdit ? t('editProduct') : t('addProduct')}
          </SheetTitle>
        </SheetHeader>

        <Formik
          enableReinitialize
          initialValues={{
            product_name: isEdit ? product.ProductName || '' : '',
            product_price: isEdit ? product.UnitPrice || '' : '',
            product_vat: isEdit ? product.VATTypeID || '' : 2,
            product_desc: isEdit ? product.ProductDesc || '' : "",
            isDisbursement: isEdit ? product.IsDisbursement || false : false,
            vatExemptionCode: isEdit ? product.VATExemptionCode || null : null,
          }}
          validationSchema={Yup.object({
            product_name: Yup.string().required(t('productNameRequired')),
            product_price: Yup.number()
              .typeError(t('productPriceNumber'))
              .required(t('productPriceRequired'))
              .min(0, t('productPriceMin')),
            product_vat: Yup.string().required(t('productVatRequired')),
          })}
          onSubmit={(values) => {
            const payload = {
              productName: values.product_name,
              unitPrice: parseFloat(values.product_price),
              vatType: parseFloat(values.product_vat),
              productDesc: values.product_desc,
              isDisbursement: values.isDisbursement,
              vatExemptionCode: values.vatExemptionCode
            };
            if (isEdit) payload.productId = product.ProductID;
            createProductMutation.mutate(payload);
          }}
        >
          {({ values, handleChange, setFieldValue, resetForm, dirty }) => {
            dirtyRef.current = dirty;

            return (
              <Form className="mt-4">
                <div className='px-3 space-y-4'>

                  <FloatLabelInput
                    id="product_name"
                    name="product_name"
                    label={t('productName')}
                    value={values.product_name}
                    onChange={handleChange}
                    required
                  />
                  <ErrorMessage name="product_name" component="div" className="text-red-500 text-xs" />

                  <CurrencyInput
                    id="product_price"
                    name="product_price"
                    label={t('unitPrice')}
                    value={values.product_price}
                    onChange={(val) => setFieldValue('product_price', val)}
                    required
                  />
                  <ErrorMessage name="product_price" component="div" className="text-red-500 text-xs" />

                  <FloatLabelSelect
                    id="product_vat"
                    name="product_vat"
                    label={t('vat')}
                    value={values.product_vat}
                    onChange={(e) => {
                      setFieldValue("product_vat", e.target.value);
                      if (parseFloat(e.target.value) === 1) {
                        setShowVATExemptionModal(true);
                      } else {
                        setFieldValue("vatExemptionCode", null);
                      }
                    }}
                    options={vatList}
                    labelKey="VATTypeName"
                    valueKey="VATTypeID"
                  />

                  <FloatLabelTextarea
                    id="product_desc"
                    name="product_desc"
                    label={t('note')}
                    value={values.product_desc}
                    onChange={(e) => setFieldValue("product_desc", e.target.value)}
                  />

                </div>

                <SheetFooter className="border-0">

                  {error && <Message variant="error" message={error} />}

                  <div className="flex justify-between gap-3">

                    <div className="flex items-center gap-2">
                      <label>{t('disbursement')}</label>
                      <Checkbox
                        checked={values.isDisbursement}
                        onCheckedChange={(checked) => {
                          setFieldValue('isDisbursement', checked);
                          setFieldValue("product_vat", checked ? 1 : 2);
                        }}
                      />
                    </div>

                    <div className='flex gap-2'>

                      {/* ✅ CLOSE BUTTON */}
                      <Button
                        type="button"
                        onClick={() => handleSheetOpenChange(false)}
                        variant="outline"
                      >
                        {t('close')}
                      </Button>

                      {/* CANCEL */}
                      {dirty && (
                        <Button
                          type="button"
                          onClick={() => resetForm()}
                          variant="outline"
                        >
                          {t('cancel')}
                        </Button>
                      )}

                      <Button
                        type="submit"
                        disabled={!dirty}
                        loading={createProductMutation.isPending}
                      >
                        {isEdit ? t('save') : t('addNew')}
                      </Button>

                    </div>
                  </div>
                </SheetFooter>

                {/* VAT MODAL */}
                <Dialog open={showVATExemptionModal} onOpenChange={setShowVATExemptionModal}>
                  <DialogContent>
                    <DialogHeader>
                      <DialogTitle>{t('selectVATExemptionCode')}</DialogTitle>
                    </DialogHeader>

                    {vatExemptionCodes.map(code => (
                      <button
                        key={code}
                        onClick={() => {
                          setFieldValue("vatExemptionCode", code);
                          setShowVATExemptionModal(false);
                        }}
                        className="w-full p-2 border rounded mb-2"
                      >
                        {code}
                        {values.vatExemptionCode === code && <CircleCheck className="inline ml-2" />}
                      </button>
                    ))}
                  </DialogContent>
                </Dialog>

              </Form>
            );
          }}
        </Formik>
      </SheetContent>

      {/* ✅ UNSAVED CHANGES DIALOG */}
      <Dialog open={showUnsavedWarning} onOpenChange={cancelClose}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>{t('unsavedChanges')}</DialogTitle>
          </DialogHeader>

          <p>{t('unsavedChangesMessage')}</p>

          <div className="flex justify-end gap-3 mt-4">
            <Button onClick={cancelClose} variant="outline">
              {t('no')}
            </Button>
            <Button onClick={confirmClose} variant="destructive">
              {t('yes')}
            </Button>
          </div>
        </DialogContent>
      </Dialog>

    </Sheet>
  );
}
