import React, { useState, useRef } from "react"
import { CModal, CModalHeader, CModalTitle, CModalBody, CModalFooter, CButton, CFormInput, CFormSelect, CSpinner } from "@coreui/react"
import api from "../../api/api"

const AddUserForm = ({ visible, meta, onClose, onSaved }) => {

    const [form, setForm] = useState({ Name: "", Email: "", Password: "", CompanyName: "", RoleName: "", DesignationName: "" })
    const [errors, setErrors] = useState({})
    const [isSaving, setIsSaving] = useState(false)
    const resetForm = () => {
        setForm({ Name: "", Email: "", Password: "", CompanyName: "", RoleName: "", DesignationName: "" })
        setErrors({})
    }
    const refs = {
        Name: useRef(),
        Email: useRef(),
        Password: useRef(),
        CompanyName: useRef(),
        RoleName: useRef(),
        DesignationName: useRef()
    }

    const validateField = (name, value) => {
        let message = ""

        if (!value || !value.trim()) { message = `${name} is required` }
        if (name === "Email" && value) {
            const emailRegex = /^[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$/
            if (!emailRegex.test(value)) message = "Invalid email format"
        }
        if (name === "Password" && value) {
            const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{6,}$/
            if (!passwordRegex.test(value))  message = "Password must be 6+ chars, include uppercase, lowercase, number" ;
        }
        // if (name === "Password" && value && value.length < 6) { message = "Password must be at least 6 characters" }
        setErrors(prev => ({ ...prev, [name]: message }))
        return message
    }

    const handleChange = (e) => {
        const { name, value } = e.target
        setForm(prev => ({ ...prev, [name]: value }))
        if (!value.trim()) validateField(name, value)
        else setErrors(prev => ({ ...prev, [name]: "" }))
    }

    const handleBlur = (e) => { validateField(e.target.name, e.target.value) }

    const validateForm = () => {
        let newErrors = {}
        Object.keys(form).forEach(field => {
            const msg = validateField(field, form[field])
            if (msg) newErrors[field] = msg
        })
        setErrors(newErrors)

        const firstError = Object.keys(newErrors)[0]
        if (firstError) {
            refs[firstError].current.focus()
            document.querySelector(".is-invalid")?.scrollIntoView({ behavior: "smooth", block: "center" })
            return false
        }
        return true
    }

    const handleSave = async () => {
        if (!validateForm()) return
        try {
            setIsSaving(true)
            await api.post("/register", form)
            onSaved()
            onClose()
            setForm({ Name: "", Email: "", Password: "", CompanyName: "", RoleName: "", DesignationName: "" })
            setErrors({})
        } catch (err) {
            alert(err.response?.data?.message || "Failed to add user")
        } finally {
            setIsSaving(false)
        }
    }

    return (
        // Add user form
        <CModal visible={visible} backdrop={isSaving ? "static" : true} keyboard={!isSaving} onClose={() => { if (!isSaving) { resetForm(), onClose() } }} >
            <CModalHeader closeButton={false} className="d-flex justify-content-between align-items-center">
                <CModalTitle className="mb-0">Add User</CModalTitle>
                <span style={isSaving ? { cursor: "not-allowed" } : {}}> <CButton type="button" className="btn-close" disabled={isSaving} onClick={() => !isSaving && onClose()} /> </span>
            </CModalHeader>
            <CModalBody>
                <CFormInput label="Name" name="Name" value={form.Name} onChange={handleChange} onBlur={handleBlur} invalid={!!errors.Name} ref={refs.Name} className="mb-2" disabled={isSaving} />
                <div className="text-danger">{errors.Name}</div>
                <CFormInput label="Email" name="Email" value={form.Email} onChange={handleChange} onBlur={handleBlur} invalid={!!errors.Email} ref={refs.Email} className="mb-2" disabled={isSaving} />
                <div className="text-danger">{errors.Email}</div>
                <CFormInput type="password" label="Password" name="Password" value={form.Password} onChange={handleChange} onBlur={handleBlur} invalid={!!errors.Password} ref={refs.Password} className="mb-2" disabled={isSaving} />
                <div className="text-danger">{errors.Password}</div>
                <CFormSelect label="Company" name="CompanyName" value={form.CompanyName} onChange={handleChange} invalid={!!errors.CompanyName} ref={refs.CompanyName} disabled={isSaving} className="mb-2" >
                    <option value="">-- Select Company --</option>
                    {meta.companies.map(c => (<option key={c.CompanyID} value={c.CompanyName}>{c.CompanyName}</option>))}
                </CFormSelect>
                <CFormSelect label="Role" name="RoleName" value={form.RoleName} onChange={handleChange} invalid={!!errors.RoleName} ref={refs.RoleName} disabled={isSaving} className="mb-2" >
                    <option value="">-- Select Role --</option>
                    {meta.roles.map(r => (<option key={r.RoleID} value={r.RoleName}>{r.RoleName}</option>))}
                </CFormSelect>
                <CFormSelect label="Designation" name="DesignationName" value={form.DesignationName} onChange={handleChange} invalid={!!errors.DesignationName} ref={refs.DesignationName} disabled={isSaving} className="mb-2" >
                    <option value="">-- Select Designation --</option>
                    {meta.designations.map(d => (<option key={d.DesignationID} value={d.DesignationName}>{d.DesignationName}</option>))}
                </CFormSelect>
            </CModalBody>
            <CModalFooter>
                <span style={isSaving ? { cursor: "not-allowed" } : {}}> <CButton onClick={() => { resetForm(), onClose() }} disabled={isSaving}>Cancel</CButton> </span>
                <CButton color="primary" onClick={handleSave} disabled={isSaving}> {isSaving ? <CSpinner size="sm" /> : "Add User"} </CButton>
            </CModalFooter>
        </CModal>
    )
}

export default AddUserForm
