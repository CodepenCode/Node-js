  const [onlineUsers, setOnlineUsers] = useState([]);

  useEffect(() => {
    if (user) {
      socket.emit("join", user.id);
    }

    socket.on("onlineUsers", setOnlineUsers);

    return () => {
      socket.off("onlineUsers");
    };
  }, [user]);

  return (
    <SocketContext.Provider value={{ socket, onlineUsers }}>
      {children}
    </SocketContext.Provider>
  );
};
